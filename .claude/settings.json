{
  "$comment": "Shared project settings for Wishes (bucket-list-ios). Committed to git. Personal/machine-specific overrides go in .claude/settings.local.json (gitignored). See CLAUDE.md and docs/workflows/build-and-verify.md.",
  "permissions": {
    "allow": [
      "Bash(xcodebuild *)",
      "Bash(xcrun simctl *)",
      "Bash(xcrun --sdk iphoneos swiftc *)",
      "Bash(xcrun --sdk iphoneos --show-sdk-path)",
      "Bash(xcrun --show-sdk-path*)",
      "Bash(xcode-select -p)",
      "Bash(xcodebuild -version)",
      "Bash(xcodebuild -list*)",
      "Bash(xcodebuild -showsdks)",
      "Bash(sw_vers)",
      "Bash(open -a Simulator)",
      "Bash(find BucketList *)",
      "Bash(.claude/hooks/*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "if": "Edit(*.swift)|Write(*.swift)",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/swift-parse-check.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/verify-on-stop.sh\""
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/doc-freshness.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "if": "Edit(docs/philosophy/**)|Write(docs/philosophy/**)",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-canonical.sh\""
          }
        ]
      }
    ]
  }
}
